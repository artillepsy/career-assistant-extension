{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=db;Port=5432;Database=db;Username=admin;Password=password"
  },
  "AllowedHosts": "*",
  "Gemini": {
    "Model": "gemini-3.1-flash-lite-preview",
    "PromptPath": "./prompt.txt",
    "Config": {
      "SystemInstructions": [
        "You are a helpful assistant. You must respond strictly in English only, regardless of the language used by the user.",
        "Write cover letter in the language that is used in job description"
      ],
      "Temperature": 0.1,
      "MaxOutputTokens": 1000,
      "CandidateCount": 1,
      "IsGoogleSearchOn": false
    }
  }
}
